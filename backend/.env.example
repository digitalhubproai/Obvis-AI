# Obvis Medical AI - Backend Environment Variables

# OpenRouter API Key (Get from https://openrouter.ai)
OPENROUTER_API_KEY=sk_or_your_api_key_here

# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# JWT Secret for Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this

# Allowed Origins for CORS (comma-separated)
# For local development: http://localhost:3000,http://127.0.0.1:3000
# For Hugging Face: http://localhost:3000,http://127.0.0.1:3000,https://creativesar-obvis-ai.hf.space
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
